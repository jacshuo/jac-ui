{
  "name": "@jac-ui/react",
  "version": "0.1.1",
  "description": "Cross-platform React UI component library — works in web & Electron",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacshuo/jac-ui.git"
  },
  "bugs": {
    "url": "https://github.com/jacshuo/jac-ui/issues"
  },
  "homepage": "https://jacshuo.github.io/jac-ui",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.config.cjs",
    "build": "npm run clean && npm run build:js && npm run build:css && npm run build:types",
    "dist": "npm run clean && cross-env NODE_ENV=production npm run build:js && npm run build:css -- --no-map && npm run build:types",
    "build:js": "webpack --config webpack.config.cjs",
    "build:css": "postcss src/styles/index.css -o dist/styles.css",
    "build:types": "tsc -p tsconfig.build.json",
    "build:demo": "webpack --config webpack.demo.config.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.6",
    "jsdom": "^29.0.0",
    "mini-css-extract-plugin": "^2.10.1",
    "null-loader": "^4.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwindcss",
    "cross-platform"
  ],
  "author": {
    "name": "Shuo Wang",
    "email": "jacshuo@gmail.com"
  },
  "license": "MIT"
}
